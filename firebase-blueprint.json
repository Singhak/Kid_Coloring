{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "isSubscribed": { "type": "boolean", "description": "Whether the user has a paid subscription" },
        "trialStartDate": { "type": "string", "format": "date-time", "description": "When the 30-day trial started" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["uid", "email", "isSubscribed", "trialStartDate"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
